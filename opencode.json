{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "amy",
  "instructions": ["conventions.md"],
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      }
    },
    "notion": {
      "type": "remote",
      "url": "https://mcp.notion.com/mcp"
    },
    "ember-cli": {
      "type": "local",
      "command": ["npx", "-y", "ember-cli-mcp"]
    },
    "reforge-mcp": {
      "type": "local",
      "command": [
        "/Users/valentin.berlin/code/qonto-web/packages/reforge/mcp.sh"
      ],
      "enabled": true
    },
    "figma": {
      "type": "remote",
      "url": "http://127.0.0.1:3845/mcp"
    }
  },
  "plugin": ["rtk", "@plannotator/opencode@latest"],
  "permission": {
    "external_directory": {
      "~/.ssh/**": "deny",
      "~/.config/**": "deny",
      "~/.config/opencode/**": "allow",
      "~/.claude/**": "deny",
      "~/code/**": "allow"
    },
    "read": {
      "**/.env": "deny",
      "**/.env.*": "deny",
      "**/.env.example": "allow"
    },
    "edit": {
      "**/.env": "deny",
      "**/.env.*": "deny"
    },
    "glob": {
      "**/.env": "deny",
      "**/.env.*": "deny"
    },
    "grep": {
      "**/.env": "deny",
      "**/.env.*": "deny"
    }
  }
}
