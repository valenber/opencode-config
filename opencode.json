{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "plan",
  "instructions": ["conventions.md"],
  "agent": {
    "plan": {
      "model": "github-copilot/gpt-5.2-codex"
    },
    "build": {
      "model": "github-copilot/gpt-5.2-codex"
    },
    "review": {
      "model": "github-copilot/gpt-5.2-codex"
    },
    "coach": {
      "model": "github-copilot/gpt-5.2-codex"
    }
  },
  "permission": {
    "read": {
      "**/.env*": "deny",
      "/etc/**": "deny",
      "/System/**": "deny",
      "/usr/**": "deny",
      "/var/**": "deny",
      "~/.ssh/**": "deny",
      "~/**": "ask"
    },
    "edit": {
      "**/.env*": "deny",
      "/etc/**": "deny",
      "/System/**": "deny",
      "/usr/**": "deny",
      "/var/**": "deny",
      "~/.ssh/**": "deny",
      "~/**": "ask"
    },
    "grep": {
      "**/.env*": "deny",
      "/etc/**": "deny",
      "/System/**": "deny",
      "/usr/**": "deny",
      "/var/**": "deny",
      "~/.ssh/**": "deny",
      "~/**": "ask"
    },
    "bash": {
      "*curl*": "ask",
      "*wget*": "ask"
    },
    "notion_notion-*": "ask",
    "notion_notion-fetch": "allow",
    "notion_notion-search": "allow"
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      }
    },
    "notion": {
      "type": "remote",
      "url": "https://mcp.notion.com/mcp"
    },
    "ember-cli": {
      "type": "local",
      "command": ["npx", "-y", "ember-cli-mcp"]
    },
    "reforge-mcp": {
      "type": "local",
      "command": [
        "/Users/valentin.berlin/code/qonto-web/packages/reforge/mcp.sh"
      ],
      "enabled": true
    },
    "figma": {
      "type": "remote",
      "url": "http://127.0.0.1:3845/mcp"
    }
  },
  "plugin": ["rtk"]
}
